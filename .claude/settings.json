{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(melos run:*)",
      "Bash(melos exec:*)",
      "Bash(melos list:*)",
      "Bash(melos bootstrap:*)",
      "Bash(melos clean:*)",
      "Bash(melos pod:*)",
      "Bash(dart analyze:*)",
      "Bash(dart format:*)",
      "Bash(dart test:*)",
      "Bash(dart run:*)",
      "Bash(dart pub:*)",
      "Bash(dart doc:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter pub:*)",
      "Bash(flutter create:*)",
      "Bash(fvm dart:*)",
      "Bash(fvm flutter:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(ln -s:*)",
      "Bash(readlink:*)",
      "Bash(lcov:*)",
      "Bash(genhtml:*)",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode",
      "mcp__Framelink_Figma_MCP__get_figma_data"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/dart_defines/*.env)",
      "Read(**/google-services.json)",
      "Read(**/GoogleService-Info.plist)",
      "Read(**/*.pem)",
      "Read(**/*.p8)",
      "Read(**/*.p12)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*service-account*.json)",
      "Read(~/.ssh/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/dart_defines/*.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-dart.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
